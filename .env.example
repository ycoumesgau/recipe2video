NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
RUNWAYML_API_SECRET=
OPENAI_API_KEY=
OPENAI_PLANNING_MODEL=
CURSOR_API_KEY=
CURSOR_AGENT_REPO_URL=
CURSOR_AGENT_STARTING_REF=main
CURSOR_AGENT_MODEL=gpt-5.5
CURSOR_AGENT_MODEL_REASONING=high
CURSOR_AGENT_MODEL_CONTEXT=272k
CURSOR_AGENT_MODEL_FAST=false
CURSOR_AGENT_RUNTIME=cloud
CURSOR_AGENT_LOCAL_CWD=
RECIPE_AGENT_GITHUB_TOKEN=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
APP_BASE_URL=
# Set to "1" to fail fast when testing Inngest without Vercel Sandbox credentials.
DISABLE_COMPOSITION_SANDBOX_RENDER=

# --- Vercel Sandbox cloud render (composition.render.requested → renderAssemblyMp4InSandbox) ---
# Repo cloned inside the sandbox. Defaults to https://github.com/ycoumesgau/recipe2video.git
COMPOSITION_RENDER_GIT_URL=
# Branch / tag / commit SHA to clone. Order of precedence:
#   COMPOSITION_RENDER_GIT_REF > VERCEL_GIT_COMMIT_SHA > VERCEL_GIT_COMMIT_REF > "main"
COMPOSITION_RENDER_GIT_REF=
# When the repo goes private, set a GitHub PAT here (fine-grained PAT with
# "Contents: read" on this repo is enough). Leave blank for public clones.
COMPOSITION_RENDER_GIT_TOKEN=
# Optional. Defaults to "x-access-token" which works with both classic and
# fine-grained PATs and with GitHub App installation tokens. Override only if
# you use a different auth scheme.
COMPOSITION_RENDER_GIT_USERNAME=
# Set to "1" to disable the Vercel Sandbox snapshot warm-start cache and force
# a cold install (clone + dnf + npm ci) on every render. Useful when
# debugging snapshot-related issues.
COMPOSITION_RENDER_DISABLE_SNAPSHOT_CACHE=
